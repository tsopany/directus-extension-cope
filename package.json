{
	"name": "directus-extension-cope",
	"description": "CoPe: Sync Directus Configs",
	"icon": "extension",
	"version": "1.1.3",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-hook"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "hook",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^10.10.0"
	},
	"scripts": {
		"build": "pnpm fix && directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate",
		"format": "prettier --log-level silent --write \"src/**/*.{js,json,ts}\"",
		"fix": "pnpm i && pnpm dedupe && pnpm format",
		"l": "pnpm up -i -L"
	},
	"dependencies": {
		"@directus/extensions": "^3.0.20",
		"@types/fs-extra": "^11.0.4",
		"fs-extra": "^11.3.4"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.0.10",
		"@types/node": "^25.3.5",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.30.3"
}
