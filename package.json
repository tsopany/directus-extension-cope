{
	"name": "directus-extension-cope",
	"description": "CoPe: Sync Directus Configs",
	"icon": "extension",
	"version": "1.1.6",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-hook"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "hook",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^10.10.0"
	},
	"scripts": {
		"build": "pnpm fix && directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate",
		"lint": "eslint src test --no-fix",
		"linter": "eslint src test --no-fix --quiet",
		"lint:fix": "eslint src test --fix",
		"format": "prettier --log-level silent --write \"src/**/*.{js,json,ts}\"",
		"fix": "pnpm i && pnpm dedupe && skeletest -f && pnpm format && git add test && pnpm lint:fix && pnpm test",
		"quick": "vitest run",
		"test": "vitest run --coverage",
		"test:watch": "vitest watch",
		"l": "pnpm up -i -L"
	},
	"dependencies": {
		"@directus/extensions": "^3.0.22",
		"@types/fs-extra": "^11.0.4",
		"fs-extra": "^11.3.4",
		"skeletest": "^0.7.4"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.1.0",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.1",
		"eslint": "^10.1.0",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vitest": "^4.1.1"
	},
	"packageManager": "pnpm@10.33.0"
}
